# OctoLink — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
POSTGRES_DB=octolink
POSTGRES_USER=octolink
POSTGRES_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────
# NATS / Message Bus
# ─────────────────────────────────────────────
NATS_URL=nats://nats:4222

# NATS mTLS (leaf-node) — provide full PEM content or paths
# NATS_TLS_CA=<PEM content or path>
# NATS_TLS_CERT=<PEM content or path>
# NATS_TLS_KEY=<PEM content or path>

# ─────────────────────────────────────────────
# Backend / API
# ─────────────────────────────────────────────
API_PORT=8080
JWT_SECRET=CHANGE_ME
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ─────────────────────────────────────────────
# Deployment
# ─────────────────────────────────────────────
COMPOSE_PROJECT_NAME=octolink
DOMAIN=localhost
