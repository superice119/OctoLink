# Environment & secrets — NEVER commit to a public repo
.env
.env.*
!.env.example
!.env.*.example

# TLS / mTLS certificates and keys (NATS, MQTT, etc.)
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
certs/
certificates/
ssl/

# Docker compose secret files
*-secret.yaml
*-secret.yml
docker-compose.override.yml
docker-compose.prod.yml

# Runtime data
data/
volumes/
logs/

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
.next/
.nuxt/
out/
build/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
vendor/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# OS
.DS_Store
*.tmp
*.bak

# Coverage & test artifacts
coverage/
*.lcov
.nyc_output/

# --- merged from upstream oktopus .gitignore ---
main
*.out
go.work
*.log
*.db
*.csr
*.db.new
*.pwd
*.acl
main
mochi

