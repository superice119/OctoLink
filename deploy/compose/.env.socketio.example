# SocketIO real-time communication service settings

# NATS server address — plain host:port only, no inline user:pass credentials.
# Inline credentials (nats://user:pass@host:4222) cause nats.js to misparse the
# URL and raise ERR_INVALID_URL.  Use NATS_USER / NATS_PASS below instead.
NATS_URL=nats://msg_broker:4222

# NATS credentials passed as separate fields so nats.js receives a clean server URL.
NATS_USER=oktopususer
NATS_PASS=change_me_in_production

# TLS — set to true and supply certificate paths when NATS is configured with mTLS.
# Cert files are expected under ./nats_config/ (mounted to /tmp/nats/config in the
# container via the docker-compose volume).
NATS_ENABLE_TLS=true
CLIENT_CRT=/tmp/nats/config/cert.pem
CLIENT_KEY=/tmp/nats/config/key.pem
SERVER_CA=/tmp/nats/config/rootCA.pem
